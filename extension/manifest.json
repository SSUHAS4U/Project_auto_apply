{
  "manifest_version": 3,
  "name": "JobPilot Assistant",
  "version": "0.9.5",
  "description": "Autofill job forms (Google/MS Forms, ATS) and save listings to your JobPilot tracker. You always review & submit.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications",
    "sidePanel",
    "webNavigation"
  ],
  "host_permissions": [
    "https://jobpilot-backend-owb0.onrender.com/*",
    "http://localhost:8080/*",
    "https://docs.google.com/*",
    "https://forms.gle/*",
    "https://forms.office.com/*",
    "https://*.linkedin.com/*",
    "https://*.naukri.com/*",
    "https://*.indeed.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "JobPilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/forms/*",
        "https://forms.gle/*"
      ],
      "js": [
        "content/common/smartFill.js",
        "content/common/fieldEngine.js",
        "content/common/assistEngine.js",
        "content/sites/googleForms.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://forms.office.com/*"
      ],
      "js": [
        "content/common/smartFill.js",
        "content/common/fieldEngine.js",
        "content/common/assistEngine.js",
        "content/sites/msForms.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/view/*"
      ],
      "js": [
        "content/common/smartFill.js",
        "content/common/fieldEngine.js",
        "content/common/assistEngine.js",
        "content/sites/linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.naukri.com/*"
      ],
      "js": [
        "content/common/smartFill.js",
        "content/common/fieldEngine.js",
        "content/common/assistEngine.js",
        "content/sites/naukri.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.indeed.com/*"
      ],
      "js": [
        "content/common/smartFill.js",
        "content/common/fieldEngine.js",
        "content/common/assistEngine.js",
        "content/sites/indeed.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/common/smartFill.js",
        "content/common/fieldEngine.js",
        "content/common/assistEngine.js",
        "content/sites/workday.js",
        "content/sites/generic.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}
