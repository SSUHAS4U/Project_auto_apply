# ============================================================================
# JobPilot environment — copy to .env and fill in. NEVER commit the real .env.
# ============================================================================

# --- API security -----------------------------------------------------------
# Static token required on every /api/** request (header: X-Api-Token).
# Generate a strong random value, e.g.:  openssl rand -hex 32
JOBPILOT_API_TOKEN=change-me-to-a-long-random-string

# --- Database (Supabase Postgres) -------------------------------------------
# Supabase: Project Settings -> Database -> Connection string (URI), session pooler.
# Convert to JDBC form:  jdbc:postgresql://HOST:PORT/postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/jobpilot
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- CORS (dashboard origin + extension id) ---------------------------------
JOBPILOT_CORS_ORIGINS=http://localhost:5173

# --- Email (Gmail SMTP, app password) ---------------------------------------
# Gmail -> Manage account -> Security -> 2FA -> App passwords.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=you@gmail.com
SPRING_MAIL_PASSWORD=your-16-char-app-password
JOBPILOT_MAIL_FROM=you@gmail.com
JOBPILOT_MAIL_DIGEST_TO=you@gmail.com
# Max email-apply sends per day (deliverability guardrail)
JOBPILOT_MAIL_DAILY_LIMIT=25

# --- Cover-letter LLM provider ----------------------------------------------
# provider = ollama | gemini | template
JOBPILOT_COVERLETTER_PROVIDER=template
JOBPILOT_OLLAMA_URL=http://localhost:11434
JOBPILOT_OLLAMA_MODEL=llama3.1
JOBPILOT_GEMINI_API_KEY=
JOBPILOT_GEMINI_MODEL=gemini-1.5-flash

# --- Connector credentials (all free tier; leave blank to disable) ----------
# Adzuna: https://developer.adzuna.com/  (free app_id + app_key)
JOBPILOT_ADZUNA_APP_ID=
JOBPILOT_ADZUNA_APP_KEY=
JOBPILOT_ADZUNA_COUNTRY=in
JOBPILOT_ADZUNA_QUERIES=java developer,backend engineer
JOBPILOT_ADZUNA_WHERE=India

# Jooble: https://jooble.org/api/about  (free key)
JOBPILOT_JOOBLE_KEY=
JOBPILOT_JOOBLE_KEYWORDS=java developer

# --- Match engine -----------------------------------------------------------
JOBPILOT_DIGEST_MIN_SCORE=60

# --- Resume storage ---------------------------------------------------------
# Local dir (kept out of git). Phase 2+ can swap to Supabase storage bucket.
JOBPILOT_RESUME_DIR=./uploads
